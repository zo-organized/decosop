@using DecoSOP.Services
@using DecoSOP.Models
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.WebUtilities
@inject InventoryService InvService
@inject DataCacheService Cache
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<div class="inv-layout">
    <div class="inv-menu-col">
        <InventoryMenu />
    </div>

    <div class="inv-list-col">
        <div class="inv-toolbar">
            @if (Scope is "all" or "category")
            {
                <input class="form-control form-control-sm" placeholder="Search items…"
                       @bind="search" @bind:event="oninput" @onkeyup="OnSearchKey" />
                <select class="form-select form-select-sm" @bind="kindFilter" @bind:after="Reload">
                    <option value="">All kinds</option>
                    <option value="Asset">Assets</option>
                    <option value="Consumable">Supplies</option>
                </select>
                <select class="form-select form-select-sm" @bind="locationFilter" @bind:after="Reload">
                    <option value="0">All locations</option>
                    @foreach (var l in locations) { <option value="@l.Id">@l.Name</option> }
                </select>
            }
            @if (Scope == "expiring")
            {
                <label class="small text-muted">Within</label>
                <select class="form-select form-select-sm" style="max-width:120px;" @bind="expiringDays" @bind:after="Reload">
                    <option value="30">30 days</option>
                    <option value="60">60 days</option>
                    <option value="90">90 days</option>
                </select>
            }
            <span class="text-muted small">@items.Count item@(items.Count == 1 ? "" : "s")</span>
            @if (view == "detail")
            {
                <span class="inv-editing-as">
                    <label class="small text-muted mb-0">Editing as</label>
                    <select class="form-select form-select-sm" @bind="editingStaff">
                        <option value="">— pick your name —</option>
                        @foreach (var s in staff) { <option value="@s.Name">@s.Name</option> }
                    </select>
                    @if (string.IsNullOrWhiteSpace(editingStaff))
                    {
                        <span class="small text-danger">pick a name to edit</span>
                    }
                    else if (!string.IsNullOrWhiteSpace(savedMsg))
                    {
                        <span class="small text-success">@savedMsg</span>
                    }
                </span>
            }
            <div class="inv-view-toggle">
                <button class="@(view == "summary" ? "active" : "")" @onclick='() => view = "summary"'>Summary</button>
                <button class="@(view == "detail" ? "active" : "")" @onclick='() => view = "detail"'>List</button>
            </div>
            <div class="inv-toolbar-actions">
                <div class="inv-scanbox">
                    <span class="inv-scan-icon">&#128269;</span>
                    <input class="form-control form-control-sm" placeholder="Scan / find barcode…"
                           @bind="scanCode" @bind:event="oninput" @onkeyup="OnScanKey" />
                </div>
                <a class="btn btn-sm btn-primary" href="inventory/new">+ New Item</a>
                <a class="btn btn-sm btn-outline-secondary" href="inventory/manage">Manage</a>
            </div>
        </div>

        @if (loading)
        {
            <SkeletonCards />
        }
        else if (view == "detail")
        {
            <InventoryItemGrid Items="items" Locations="locations" Categories="categories"
                               EditingStaff="@editingStaff" OnSaved="OnGridSaved" OnChanged="Refresh" />
        }
        else
        {
            <InventoryItemList Items="items" SelectedId="selected?.Id" OnRowClick="Select" ShowCategory="true" View="summary" />
        }
    </div>

    @if (view == "summary")
    {
        <div class="inv-side-col">
            <InventoryDetailPanel Item="selected" Staff="staff" OnChanged="Refresh"
                                  OnEdit="EditItem" OnClose="() => selected = null" />
        </div>
    }
</div>

@code {
    [Parameter] public string Scope { get; set; } = "all";
    [Parameter] public int? CategoryId { get; set; }

    private List<InventoryItem> items = [];
    private List<InventoryLocation> locations = [];
    private List<InventoryStaff> staff = [];
    private List<InventoryCategory> categories = [];
    private InventoryItem? selected;
    private string search = "";
    private string kindFilter = "";
    private string locationFilter = "0";
    private int expiringDays = 30;
    private string view = "summary";
    private string scanCode = "";
    private string editingStaff = "";
    private string? savedMsg;
    private bool loading = true;
    private bool _selHandled;
    private string? _loadedKey;
    private System.Timers.Timer? _debounce;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        locations = await Cache.GetInvLocationsAsync();
        staff = await Cache.GetInvStaffAsync();
        categories = await Cache.GetInvTreeAsync();
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (Scope != "all") return;
        try
        {
            var q = QueryHelpers.ParseQuery(Nav.ToAbsoluteUri(Nav.Uri).Query);
            var newView = q.TryGetValue("view", out var vv) && vv == "detail" ? "detail" : "summary";
            InventoryItem? it = null;
            if (q.TryGetValue("sel", out var sv) && int.TryParse(sv, out var selId))
                it = items.FirstOrDefault(i => i.Id == selId)
                    ?? await Cache.RunExclusiveAsync(() => InvService.GetItemAsync(selId));
            await InvokeAsync(() => { view = newView; if (it is not null) selected = it; StateHasChanged(); });
        }
        catch (ObjectDisposedException) { }
    }

    private void ReadViewFromQuery()
    {
        var q = QueryHelpers.ParseQuery(Nav.ToAbsoluteUri(Nav.Uri).Query);
        view = q.TryGetValue("view", out var vv) && vv == "detail" ? "detail" : "summary";
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Scope == "all") ReadViewFromQuery();
        var key = $"{Scope}:{CategoryId}";
        if (key == _loadedKey) return;
        _loadedKey = key;
        selected = null;
        _selHandled = false;
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        StateHasChanged();
        try
        {
            int? locId = locationFilter != "0" && int.TryParse(locationFilter, out var lp) ? lp : null;
            InventoryKind? kind = Enum.TryParse<InventoryKind>(kindFilter, out var k) ? k : null;

            items = await Cache.RunExclusiveAsync(() => Scope switch
            {
                "low" => InvService.GetLowStockAsync(),
                "expiring" => InvService.GetExpiringAsync(expiringDays),
                "category" => InvService.GetItemsAsync(CategoryId, locId, kind, string.IsNullOrWhiteSpace(search) ? null : search),
                _ => InvService.GetItemsAsync(null, locId, kind, string.IsNullOrWhiteSpace(search) ? null : search)
            });

            if (selected is not null)
                selected = items.FirstOrDefault(i => i.Id == selected.Id)
                    ?? await Cache.RunExclusiveAsync(() => InvService.GetItemAsync(selected.Id));

            // Handle a ?sel=<id> deep-link (used by the barcode scanner) once.
            if (!_selHandled && Scope == "all")
            {
                _selHandled = true;
                var q = QueryHelpers.ParseQuery(Nav.ToAbsoluteUri(Nav.Uri).Query);
                if (q.TryGetValue("sel", out var sv) && int.TryParse(sv, out var selId))
                    selected = items.FirstOrDefault(i => i.Id == selId)
                        ?? await Cache.RunExclusiveAsync(() => InvService.GetItemAsync(selId));
            }
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private Task Reload() => Load();

    private void Select(InventoryItem item) => selected = item;

    private async Task Refresh()
    {
        Cache.InvalidateInv();
        locations = await Cache.GetInvLocationsAsync();
        staff = await Cache.GetInvStaffAsync();
        categories = await Cache.GetInvTreeAsync();
        await Load();
    }

    private void EditItem(InventoryItem item) => Nav.NavigateTo($"inventory/edit/{item.Id}");

    private void OnGridSaved(string msg) => savedMsg = msg;

    private async Task OnScanKey(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        var code = scanCode?.Trim() ?? "";
        if (code.Length == 0) return;

        var item = await Cache.RunExclusiveAsync(() => InvService.LookupByBarcodeAsync(code));
        scanCode = "";
        if (item is not null)
        {
            selected = item;
            view = "summary";
        }
        else
        {
            var create = await JS.InvokeAsync<bool>(
                "confirm", $"No item has barcode \"{code}\". Create a new item with this barcode?");
            if (create) Nav.NavigateTo($"inventory/new?barcode={Uri.EscapeDataString(code)}");
        }
    }

    private void OnSearchKey()
    {
        _debounce?.Stop();
        _debounce?.Dispose();
        _debounce = new System.Timers.Timer(300) { AutoReset = false };
        _debounce.Elapsed += async (_, _) =>
        {
            await InvokeAsync(Load);
        };
        _debounce.Start();
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        _debounce?.Stop();
        _debounce?.Dispose();
    }
}
