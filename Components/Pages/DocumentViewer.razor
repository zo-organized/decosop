@page "/documents/{Id:int}"
@using DecoSOP.Services
@using DecoSOP.Models
@inject DocumentService DocService
@inject UserPreferenceService Prefs
@inject DataCacheService Cache
@inject ContextMenuState MenuState
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(document?.Title ?? "Document") - DecoSOP</PageTitle>

@if (document is null)
{
    <p>Loading...</p>
}
else
{
    <div class="sop-viewer">
        <div class="sop-toolbar">
            <button class="btn btn-sm btn-outline-secondary me-2" @onclick="GoBack" title="Back to category">
                &larr; Back
            </button>
            <span class="sop-breadcrumb">@categoryPath / @document.Title</span>
            <button class="btn-star btn-star-lg @(isFavorited ? "starred" : "")"
                    title="@(isFavorited ? "Remove from favorites" : "Add to favorites")"
                    @onclick="ToggleFavorite">
                @(isFavorited ? "\u2605" : "\u2606")
            </button>
            <div class="sop-actions">
                @if (openUri is not null)
                {
                    <a class="btn btn-sm btn-success" href="@openUri">Open in @openApp</a>
                }
                @if (canPreview)
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="PrintDocument">Print</button>
                }
                <button class="btn btn-sm btn-outline-primary" @onclick="ToggleReplacePanel">Replace file</button>
                <a class="btn btn-sm btn-primary" href="/api/documents/@document.Id/download" target="_blank">Download</a>
            </div>
        </div>

        @if (showReplacePanel)
        {
            <div class="alert alert-info mt-2">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span>Replace with an updated <strong>@DocumentService.GetFileExtension(document.FileName)</strong> file:</span>
                    <InputFile OnChange="OnReplaceFileSelected" accept="@fileExt" class="form-control form-control-sm" style="max-width:320px;" disabled="@isReplacing" />
                    <button class="btn btn-sm btn-primary" @onclick="DoReplace" disabled="@(isReplacing || replaceFile is null)">
                        @(isReplacing ? "Replacing..." : "Replace")
                    </button>
                    <button class="btn btn-sm btn-secondary" @onclick="() => showReplacePanel = false" disabled="@isReplacing">Cancel</button>
                </div>
                @if (!string.IsNullOrEmpty(replaceError))
                {
                    <div class="mt-2 text-danger small">@replaceError</div>
                }
            </div>
        }

        @* --- Inline previews by file type --- *@
        @if (isImage)
        {
            <div class="doc-preview">
                <img src="/api/documents/@document.Id/preview" alt="@document.Title" class="doc-preview-image" />
            </div>
        }
        else if (isPdf)
        {
            <div class="doc-preview">
                <iframe src="/api/documents/@document.Id/preview" class="doc-preview-frame"></iframe>
            </div>
        }
        else if (isConvertible)
        {
            @* Office documents: converted to PDF by LibreOffice for full-fidelity viewing *@
            <div class="doc-preview">
                @if (converting)
                {
                    <div class="converting-indicator">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <span>Generating preview (first view may take a moment)...</span>
                    </div>
                }
                <iframe id="pdf-preview-frame" src="about:blank" class="doc-preview-frame @(converting ? "d-none" : "")"></iframe>
            </div>
        }
        else
        {
            <div class="doc-meta">
                <div class="doc-meta-row">
                    <span class="doc-meta-label">File</span>
                    <span>@document.FileName</span>
                </div>
                <div class="doc-meta-row">
                    <span class="doc-meta-label">Type</span>
                    <span>
                        <span class="file-type-badge badge-@DocumentService.GetFileExtension(document.FileName).ToLower()">
                            @DocumentService.GetFileExtension(document.FileName)
                        </span>
                    </span>
                </div>
                <div class="doc-meta-row">
                    <span class="doc-meta-label">Size</span>
                    <span>@DocumentService.FormatFileSize(document.FileSize)</span>
                </div>
                <div class="doc-meta-row">
                    <span class="doc-meta-label">Category</span>
                    <span>@categoryPath</span>
                </div>
                <div class="doc-meta-row">
                    <span class="doc-meta-label">Uploaded</span>
                    <span>@document.CreatedAt.ToLocalTime().ToString("MMMM d, yyyy h:mm tt")</span>
                </div>
            </div>
            <div class="download-section">
                <a class="download-btn" href="/api/documents/@document.Id/download" target="_blank">
                    Download @document.FileName
                </a>
            </div>
        }
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private OfficeDocument? document;
    private string categoryPath = string.Empty;
    private bool isFavorited;
    private bool converting;
    private bool pdfLoaded;

    private string fileExt => Path.GetExtension(document?.FileName ?? "").ToLowerInvariant();
    private bool isPdf => document?.ContentType == "application/pdf";
    private bool isImage => document?.ContentType?.StartsWith("image/") == true;
    private bool isConvertible => PdfConversionService.CanConvert(document?.FileName ?? "");
    private bool canPreview => isPdf || isImage || isConvertible;

    private bool showReplacePanel;
    private bool isReplacing;
    private string replaceError = string.Empty;
    private IBrowserFile? replaceFile;
    private string? openUri;
    private string? openApp;

    protected override async Task OnParametersSetAsync()
    {
        document = await Cache.RunExclusiveAsync(() => DocService.GetDocumentAsync(Id));
        pdfLoaded = false;
        converting = false;
        openUri = null;
        openApp = null;
        if (document is not null)
        {
            categoryPath = await Cache.RunExclusiveAsync(() => DocService.GetCategoryPathAsync(document.CategoryId));
            var prefs = await Cache.GetDocDocPrefsAsync();
            isFavorited = prefs.TryGetValue(Id, out var p) && p.IsFavorited;
            openApp = OfficeProtocol.For(document.FileName)?.App;
            openUri = OfficeProtocol.OpenForEditUri(document.FileName, document.StoredFileName,
                DocumentService.OpenBase, DocService.GetFilePath(document));
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (document is not null && isConvertible && !pdfLoaded)
        {
            pdfLoaded = true;
            converting = true;
            StateHasChanged();

            // Set the iframe src to the PDF preview endpoint
            // The server will convert on first access and cache for subsequent views
            var pdfUrl = $"/api/documents/{document.Id}/preview-pdf";
            await JS.InvokeVoidAsync("documentInterop.loadPdfPreview", "pdf-preview-frame", pdfUrl);

            converting = false;
            StateHasChanged();
        }
    }

    private void GoBack()
    {
        if (document is not null)
            Nav.NavigateTo($"/documents/category/{document.CategoryId}");
        else
            Nav.NavigateTo("/documents");
    }

    private async Task ToggleFavorite()
    {
        if (document is null) return;
        isFavorited = await Cache.RunExclusiveAsync(() => Prefs.ToggleFavoriteAsync(nameof(OfficeDocument), document.Id));
        Cache.InvalidateDocFavorites();
    }

    private async Task PrintDocument()
    {
        if (document is null) return;

        if (isConvertible)
        {
            // Open the converted PDF in a new tab and print it directly
            await JS.InvokeVoidAsync("documentInterop.printPdf", $"/api/documents/{document.Id}/preview-pdf");
        }
        else if (isPdf)
        {
            var previewUrl = $"/api/documents/{document.Id}/preview";
            await JS.InvokeVoidAsync("documentInterop.printFile", previewUrl, document.ContentType, document.Title);
        }
        else if (isImage)
        {
            var previewUrl = $"/api/documents/{document.Id}/preview";
            await JS.InvokeVoidAsync("documentInterop.printFile", previewUrl, document.ContentType, document.Title);
        }
    }

    private void ToggleReplacePanel()
    {
        showReplacePanel = !showReplacePanel;
        replaceError = string.Empty;
        replaceFile = null;
    }

    private void OnReplaceFileSelected(InputFileChangeEventArgs e)
    {
        replaceFile = e.File;
        replaceError = string.Empty;
    }

    private async Task DoReplace()
    {
        if (document is null || replaceFile is null) return;
        isReplacing = true;
        replaceError = string.Empty;
        try
        {
            await Cache.RunExclusiveAsync(() => DocService.ReplaceFileAsync(document.Id, replaceFile));
            Cache.InvalidateDoc();
            await MenuState.NotifyCategoryModified();
            document = await Cache.RunExclusiveAsync(() => DocService.GetDocumentAsync(Id));
            showReplacePanel = false;
            replaceFile = null;
            pdfLoaded = false; // re-trigger preview regeneration from the updated file
        }
        catch (Exception ex)
        {
            replaceError = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            isReplacing = false;
        }
    }

}
